// -*- mode: jsonc -*-
// A launch configuration compiles the extension and opens it inside a new window
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm",
            "type": "shell",
            "command": "npm", // we want to run npm
            "args": [ // we run the custom "compile" as defined in package.json
                "run",
                "compile",
                "--loglevel",
                "silent"
            ],
            "isBackground": true,
            "problemMatcher": "$tsc-watch",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ]
}
